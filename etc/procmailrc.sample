# mlisp procmail recipes — namespace-subgroup convention
# Generated sample — copy or append to ~/.procmailrc
#
# Replace mlisp@panix.com with your actual base address.
# To install automatically:
#   mlisp-admin install-procmail [--dry-run]
#   mlisp-admin add-namespace myproject myproject@example.com

# mlisp: mlisp-discuss
:0
* !^FROM_DAEMON
* !^FROM_MAILER
* !^Precedence: (bulk|junk|list)
* ^TO_mlisp-discuss@panix.com
| /usr/local/bin/mlisp --home /home/user/.config/mlisp mlisp-discuss

# mlisp: mlisp-discuss-request
:0
* ^TO_mlisp-request@panix.com
| /usr/local/bin/mlisp --home /home/user/.config/mlisp --mode request mlisp-request

# mlisp: mlisp-announce
:0
* !^FROM_DAEMON
* !^FROM_MAILER
* !^Precedence: (bulk|junk|list)
* ^TO_mlisp-announce@panix.com
| /usr/local/bin/mlisp --home /home/user/.config/mlisp mlisp-announce

