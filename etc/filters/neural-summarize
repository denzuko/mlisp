#!/bin/sh
# etc/filters/neural-summarize — mlisp-admin bugs-report --summarize wrapper
#
# Uses the `neural` binary, built from etc/neural-mlisp.m4 via
# `make build-all` (or `make bin/neural`). The built binary is a
# self-contained shell script (bash + curl + jq + jo at runtime).
#
# Wire up:
#   mlisp-admin bugs-report <pkg> \
#       --summarize /path/to/etc/filters/neural-summarize
#
# CONFIGURATION
#   The model and endpoint are NOT runtime-configurable -- they are
#   compiled into bin/neural at build time from etc/neural-mlisp.m4
#   (neural.sh's config.m4 DSL; see comments in that file). The
#   default is local Ollama (http://localhost:11434), so bug reports
#   -- which may contain reporter email addresses -- stay on-host.
#   To use OpenAI or another endpoint, edit etc/neural-mlisp.m4 and
#   run `make bin/neural` again.

prompt="Summarize this bug tracker report in one short paragraph. \
Highlight any critical or security-severity items first. Be concise:"

report=$(cat)

printf '%s\n\n%s' "$prompt" "$report" | neural -
