#!/bin/sh
# etc/filters/neural-summarize — mlisp-admin bugs-report --summarize wrapper
#
# Uses the neural binary built from vendor/neural.sh (via `make build-all`
# or `make -C vendor/neural.sh build` + copy to bin/). The built binary
# is a self-contained shell script requiring only: bash, curl, jq, jo.
#
# Wire up:
#   mlisp-admin bugs-report <pkg> \
#       --summarize /path/to/etc/filters/neural-summarize
#
# ENVIRONMENT
#   NEURAL_ENDPOINT — OpenAI-compatible base URL
#                     Default: http://localhost:11434/v1/completions (Ollama)
#   NEURAL_MODEL    — model name  Default: llama3.2
#   OPENAI_API_KEY  — API key (empty string is valid for Ollama)
#
# Local Ollama is the recommended default: bug reports may contain
# reporter email addresses and should not leave the host.

: "${NEURAL_ENDPOINT:=http://localhost:11434/v1/completions}"
: "${NEURAL_MODEL:=llama3.2}"

prompt="Summarize this bug tracker report in one short paragraph. \
Highlight any critical or security-severity items first. Be concise:"

report=$(cat)

printf '%s\n\n%s' "$prompt" "$report" | neural -
